rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // 🔒 DEFAULT DENY (GLOBAL SECURITY)
    // =========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================
    // 🧠 BASE HELPERS
    // =========================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "botman.xyz@gmail.com" &&
        request.auth.token.email_verified == true
      );
    }

    // =========================================
    // 👤 USER HELPERS
    // =========================================
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================
    // 👨‍👩‍👧‍👦 FAMILY RBAC HELPERS (CORE)
    // =========================================

    function memberPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid);
    }

    function memberDoc(familyId) {
      return get(memberPath(familyId));
    }

    function memberExists(familyId) {
      return exists(memberPath(familyId));
    }

    function memberRole(familyId) {
      return memberDoc(familyId).data.role;
    }

    function isMember(familyId) {
      return isAuthenticated() && memberExists(familyId);
    }

    function hasRole(familyId, roles) {
      return isMember(familyId) && memberRole(familyId) in roles;
    }

    function isOwner(familyId) {
      return hasRole(familyId, ['owner']);
    }

    function canRead(familyId) {
      return isMember(familyId) || isAdmin() || 
        (isAuthenticated() && get(/databases/$(database)/documents/families/$(familyId)).data.ownerId == request.auth.uid);
    }

    function canWrite(familyId) {
      return hasRole(familyId, ['owner', 'admin', 'editor']) || isAdmin() || 
        (isAuthenticated() && get(/databases/$(database)/documents/families/$(familyId)).data.ownerId == request.auth.uid);
    }

    function canManageMembers(familyId) {
      return hasRole(familyId, ['owner', 'admin']) || isAdmin() ||
        (isAuthenticated() && get(/databases/$(database)/documents/families/$(familyId)).data.ownerId == request.auth.uid);
    }

    // =========================================
    // ✅ VALIDATION HELPERS
    // =========================================

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'createdAt', 'role']) &&
        data.uid is string &&
        data.role == 'user';
    }

    function isValidFamily(data) {
      return data.keys().hasOnly(['name', 'ownerId', 'createdAt']) &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() < 100 &&
        data.ownerId is string;
    }

    function isValidMember(data) {
      return data.keys().hasOnly(['role', 'joinedAt']) &&
        data.role in ['owner', 'admin', 'editor', 'viewer'];
    }

    function isValidPerson(data) {
      let allowed = [
        'name', 'gender', 'createdBy', 'updatedAt',
        'maritalStatus', 'birthDate', 'deathDate',
        'photoUrl', 'fatherId', 'motherId',
        'spouseId', 'spouseIds', 'isAdoptedChild',
        'externalSpouseName', 'externalFamilyId',
        'bio', 'media', 'familyId'
      ];

      return data.keys().hasOnly(allowed) &&
        data.name is string &&
        data.name.size() > 0 &&
        data.name.size() < 100 &&
        data.gender in ['male', 'female', 'other'];
    }

    // =========================================
    // 🧪 TEST
    // =========================================
    match /test/connection {
      allow read: if true;
    }

    // =========================================
    // 👤 USERS
    // =========================================
    match /users/{userId} {

      allow read: if isAuthenticated();

      allow create: if isSelf(userId) &&
        isValidUser(request.resource.data) &&
        request.resource.data.uid == userId;

      allow update: if isSelf(userId) &&
        request.resource.data.uid == resource.data.uid;

      allow delete: if isSelf(userId) || isAdmin();

      // Private data
      match /private/{docId} {
        allow read, write: if isSelf(userId) || isAdmin();
      }
    }

    // =========================================
    // 👨‍👩‍👧‍👦 FAMILIES
    // =========================================
    match /families/{familyId} {

      allow read: if canRead(familyId);

      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid &&
        isValidFamily(request.resource.data);

      allow update: if canWrite(familyId);

      allow delete: if isOwner(familyId) || isAdmin();

      // =========================================
      // 👥 MEMBERS (RBAC)
      // =========================================
      match /members/{memberUserId} {

        allow read: if canRead(familyId);

        // Semua member yang sudah terautentikasi bisa create/update/delete
        // (sistem RBAC bisa dikembangkan nanti)
        allow create, update, delete: if isAuthenticated() && isMember(familyId);

      }

      // =========================================
      // 👨 DATA ORANG (GENEALOGY)
      // =========================================
      match /people/{personId} {

        allow read: if canRead(familyId);

        allow create: if canWrite(familyId) &&
          isValidPerson(request.resource.data) &&
          request.resource.data.createdBy == request.auth.uid;

        allow update: if canWrite(familyId) &&
          isValidPerson(request.resource.data);

        allow delete: if isOwner(familyId) || isAdmin();
      }

      // =========================================
      // 📜 AUDIT LOG (OPTIONAL)
      // =========================================
      match /logs/{logId} {
        allow read: if isOwner(familyId) || isAdmin();
        allow create: if isMember(familyId);
      }
    }
  }
}