rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // 🔒 DEFAULT DENY (GLOBAL SECURITY)
    // Open/Closed Principle: mudah extends dengan match spesifik
    // =========================================

    // =========================================
    // 🧠 BASE HELPERS (Single Responsibility)
    // =========================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "botman.xyz@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    // =========================================
    // 👤 USER HELPERS (Single Responsibility)
    // =========================================
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================
    // 👨‍👩‍👧‍👦 FAMILY RBAC HELPERS (DRY - Extract Common Logic)
    // =========================================

    // 🔄 Helper untuk ambil path document
    function docPath(collection, docId) {
      return /databases/$(database)/documents/$(collection)/$(docId);
    }

    // 🔄 Helper untuk ambil path member
    function memberPath(familyId) {
      return docPath("families/" + familyId + "/members", request.auth.uid);
    }

    // 🔄 Helper untuk cek apakah user adalah member
    function isMember(familyId) {
      return isAuthenticated() && exists(memberPath(familyId));
    }

    // 🔄 Helper untuk cek apakah user adalah owner family
    function isFamilyOwner(familyId) {
      return isAuthenticated() && 
        get(docPath("families", familyId)).data.ownerId == request.auth.uid;
    }

    // 🔄 Helper untuk cek role user dalam family
    function memberRole(familyId) {
      return get(memberPath(familyId)).data.role;
    }

    // 🔄 Helper untuk cek apakah user memiliki role tertentu
    function hasRole(familyId, allowedRoles) {
      return isMember(familyId) && memberRole(familyId) in allowedRoles;
    }

    // 🔄 Helper untuk cek izin baca ( DRY: konsolidasi logika )
    function canReadFamily(familyId) {
      return isMember(familyId) || isAdmin() || isFamilyOwner(familyId);
    }

    // 🔄 Helper untuk cek izin tulis ( DRY: konsolidasi logika )
    function canWriteFamily(familyId) {
      return hasRole(familyId, ['owner', 'admin', 'editor']) || isAdmin() || isFamilyOwner(familyId);
    }

    // =========================================
    // ✅ VALIDATION HELPERS (Single Responsibility)
    // =========================================
    
    // 🔄 Validasi field yang diizinkan saja (tidak bergantung pada semua field)
    function hasOnlyAllowedKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function isValidUser(data) {
      let requiredKeys = ['uid', 'displayName', 'photoURL', 'createdAt', 'role'];
      return hasOnlyAllowedKeys(data, requiredKeys) &&
        data.uid is string &&
        data.role == 'user';
    }

    function isValidFamily(data) {
      let requiredKeys = ['name', 'ownerId', 'createdAt'];
      return hasOnlyAllowedKeys(data, requiredKeys) &&
        isValidString(data.name, 1, 100) &&
        data.ownerId is string;
    }

    function isValidPerson(data) {
      let requiredKeys = [
        'name', 'gender', 'createdBy', 'updatedAt',
        'maritalStatus', 'birthDate', 'deathDate',
        'photoUrl', 'fatherId', 'motherId',
        'spouseId', 'spouseIds', 'isAdoptedChild',
        'externalSpouseName', 'externalFamilyId',
        'bio', 'media', 'familyId'
      ];
      return hasOnlyAllowedKeys(data, requiredKeys) &&
        isValidString(data.name, 1, 100) &&
        data.gender in ['male', 'female', 'other'];
    }

    // =========================================
    // 🚫 ANTI-INCEST HELPERS (Marriage Validation)
    // =========================================
    
    // Helper to check if spouse is from different family
    // Note: This is a basic check - complex graph validation is done in Domain Layer
    function isValidSpouseFamily(data) {
      // If setting spouseId, spouse must be from different family (anti-incest basic check)
      // Note: We cannot query other members in Firestore rules, so this is a basic guard
      // The actual validation is enforced in the Application Layer (MemberService)
      return true; // Trust the backend validation
    }

    // Helper to prevent self-spouse
    function isNotSelfSpouse(data) {
      return data.spouseId == null || data.spouseId == '' || data.spouseId != data.id;
    }

    // =========================================
    // 🧪 TEST COLLECTION (Public Read)
    // =========================================
    match /test/connection {
      allow read: if true;
    }

    // =========================================
    // 👤 USERS COLLECTION
    // =========================================
    match /users/{userId} {
      // Read: semua user terautentikasi
      allow read: if isAuthenticated();

      // Create: user hanya bisa create diri sendiri
      allow create: if isSelf(userId) &&
        isValidUser(request.resource.data) &&
        request.resource.data.uid == userId;

      // Update: user hanya bisa update diri sendiri
      allow update: if isSelf(userId) &&
        request.resource.data.uid == resource.data.uid;

      // Delete: self atau admin
      allow delete: if isSelf(userId) || isAdmin();

      // Private subcollection
      match /private/{docId} {
        allow read, write: if isSelf(userId) || isAdmin();
      }
    }

    // =========================================
    // 👨‍👩‍👧‍👦 FAMILIES COLLECTION
    // =========================================
    match /families/{familyId} {

      // Read: member, owner, atau admin
      allow read: if canReadFamily(familyId);

      // Create: user terautentikasi dan owns family baru
      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid &&
        isValidFamily(request.resource.data);

      // Update: member dengan role editor+
      allow update: if canWriteFamily(familyId);

      // Delete: owner atau admin
      allow delete: if hasRole(familyId, ['owner']) || isAdmin();

      // =========================================
      // 👥 MEMBERS SUBCOLLECTION (User Membership)
      // =========================================
      match /members/{memberUserId} {
        // Read: semua member family
        allow read: if canReadFamily(familyId);

        // Create/Update/Delete: semua user terautentikasi
        // (dapat diperketat jika RBAC sudah diimplementasi penuh)
        allow create, update, delete: if isAuthenticated();
      }

      // =========================================
      // 👨 PEOPLE SUBCOLLECTION (Genealogy Data)
      // =========================================
      match /people/{personId} {
        // Read: semua member family
        allow read: if canReadFamily(familyId);

        // Create: writer yang valid dan creator adalah user sendiri
        allow create: if canWriteFamily(familyId) &&
          isValidPerson(request.resource.data) &&
          isNotSelfSpouse(request.resource.data) &&
          request.resource.data.createdBy == request.auth.uid;

        // Update: writer yang valid + anti-incest basic check
        allow update: if canWriteFamily(familyId) &&
          isValidPerson(request.resource.data) &&
          isNotSelfSpouse(request.resource.data);

        // Delete: owner atau admin
        allow delete: if hasRole(familyId, ['owner']) || isAdmin();
      }

      // =========================================
      // 📜 AUDIT LOG SUBCOLLECTION
      // =========================================
      match /logs/{logId} {
        // Read: owner atau admin
        allow read: if hasRole(familyId, ['owner']) || isAdmin();

        // Create: semua member
        allow create: if isMember(familyId);
      }
    }
  }
}